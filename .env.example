# ============================================================================
# Databricks credentials for scripts/runbook.sh and databricks.yml
#
# Copy to .env and fill in. .env is git-ignored.
# ============================================================================

# Workspace host (no protocol — script adds https://)
DATABRICKS_HOST=adb-XXXXXXXXXXXXXXXX.X.azuredatabricks.net

# Personal access token. Generate via:
#   Databricks UI → User Settings → Access tokens → Generate new token
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# SQL warehouse ID. Find via:
#   Databricks UI → SQL warehouses → click warehouse → Connection details → ID
DATABRICKS_WAREHOUSE_ID=XXXXXXXXXXXXXXXX

# Unity Catalog catalog name (default matches packages/0.1.1/00_setup/01_config.sql)
DATABRICKS_CATALOG=medallion_demo
